      "regex": "^/api/accounts/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/accounts/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
